---
import 'normalize.css';

export interface Props {
    title: string;
    description?: string;
    image?: string;
    bigImage?: boolean;
    pagefindIgnore?: boolean;
}

const { title, description = 'a stella sora database', image = 'https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/datingeventcg/DatingSPCG_156302.webp', bigImage, pagefindIgnore } = Astro.props;

const buildTime = new Date().toISOString();

if (import.meta.env.SSR) {
    Astro.response.headers.set('Link', ['</font.woff2>; rel=preload; as=font; type=font/woff2; crossorigin', '<https://api.lanyard.rest>; rel=preconnect; crossorigin'].join(', '));
}
---

<!doctype html>
<html lang="en" {...pagefindIgnore ? { 'data-pagefind-ignore': '' } : {}}>
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width,initial-scale=0.5" />
        <meta name="google-site-verification" content="QnPzHT-3k8oi0acqMvSozJjSGyAgimpbAop5WpEQ_Oc" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <meta name="theme-color" content="#66ff99" />
        <link rel="canonical" href={Astro.url.href} />
        <meta property="og:url" content={Astro.url.href} />
        <meta property="og:type" content="website" />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={image} />
        <meta property="og:site_name" content="stelladb.pages.dev" />
        {
            bigImage && (
                <>
                    <meta name="twitter:card" content="summary_large_image" />
                    <meta name="twitter:image" content={image} />
                </>
            )
        }
        <link rel="sitemap" href="/sitemap-index.xml" />
        <script
            is:inline
            type="application/ld+json"
            set:html={JSON.stringify({
                '@context': 'http://schema.org',
                '@type': 'WebPage',
                name: title,
                description,
                image,
                url: Astro.url.href,
            })}
        />
        <script is:inline defer src="/u.js" data-website-id="a702f6da-1e9a-4d42-bf33-cc60aba3c081" data-domains="stelladb.pages.dev" data-performance="true"></script>
    </head>
    <body>
        <nav>
            <a href="/" data-astro-prefetch><div class="logo">stelladb</div></a>
            <div class="navlinks">
                <a href="/trekker" data-astro-prefetch>Trekker</a>
                <a href="/disc" data-astro-prefetch>Disc</a>
                <a href="/banner" data-astro-prefetch>Banner</a>
                <a href="/lb" data-astro-prefetch>Leaderboard</a>
                <details>
                    <summary>Monster</summary>
                    <div>
                        <a href="/ascension" data-astro-prefetch>Ascension</a>
                        <a href="/arena" data-astro-prefetch>Menace Arena</a>
                        <a href="/ground" data-astro-prefetch>Proving Ground</a>
                        <a href="/blitz" data-astro-prefetch>Boss Blitz</a>
                        <a href="/raid" data-astro-prefetch>Finale Echoing</a>
                        <a href="/duel" data-astro-prefetch>Summit Show</a>
                    </div>
                </details>
                <details>
                    <summary>Other</summary>
                    <div>
                        <a href="/build" data-astro-prefetch>Build Preset</a>
                        <a href="/emblem" data-astro-prefetch>Emblem</a>
                        <a href="/infodoc">Infodoc</a>
                        <a href="/unreleased" data-astro-prefetch>Unreleased</a>
                        <a href="https://gist.github.com/AutumnVN/91afd7a37a9743488419b70f07225950" target="_blank">Damage Formula ↗</a>
                        <a href="https://github.com/users/AutumnVN/projects/2" target="_blank">Known Issues ↗</a>
                    </div>
                </details>
            </div>
        </nav>

        <main>
            <slot />
        </main>

        <footer>
            <div class="footer-left">
                <div class="discord">
                    <a href="https://discord.com/users/393694671383166998" target="_blank">
                        <div class="avatar-wrapper">
                            <svg width="40" height="40" viewBox="0 0 40 40">
                                <defs>
                                    <mask id="mask" maskContentUnits="objectBoundingBox" viewBox="0 0 1 1">
                                        <rect fill="white" x="0" y="0" width="100%" height="100%"></rect>
                                        <circle fill="black" cx="0.82" cy="0.82" r="0.22"></circle>
                                    </mask>
                                </defs>
                                <foreignObject width="40" height="40" mask="url(#mask)">
                                    <div class="avatar"></div>
                                </foreignObject>
                            </svg>
                            <div class="color-dot"></div>
                        </div>
                        <div class="meta">
                            <div class="name-row">
                                <span class="display-name"></span>
                                <span class="username"></span>
                            </div>
                            <div class="activity-row">
                                <span class="status"></span>
                                <span class="activity"></span>
                            </div>
                        </div>
                    </a>
                </div>
            </div>
            <div class="footer-right">
                <p>
                    last build <span class="build-time" data-time={buildTime}></span>
                    <br />
                    <a href="https://github.com/AutumnVN/stelladb">site</a>
                    /
                    <a href="https://github.com/AutumnVN/StellaSoraData">data</a>
                    /
                    <a href="https://github.com/AutumnVN/ssassets">img</a>
                </p>
            </div>
        </footer>
    </body>
</html>

<script>
    // @ts-nocheck
    const tooltips = document.querySelectorAll('.tooltip');

    let rafPending = false;
    let lastX = 0;
    let lastY = 0;
    let lastEl = null;
    document.addEventListener('mousemove', (e) => {
        const el = e.target.closest('.tooltip');
        if (!el) return;
        lastX = e.pageX;
        lastY = e.pageY;
        lastEl = el;
        if (rafPending) return;
        rafPending = true;
        requestAnimationFrame(() => {
            rafPending = false;
            const tooltip = lastEl.querySelector('.tooltip-text');
            if (!tooltip) return;
            const tw = tooltip.clientWidth;
            const th = tooltip.clientHeight;
            const bw = document.body.clientWidth;
            const bh = document.body.clientHeight;
            const left = Math.min(Math.max(8, lastX + 16), bw - tw - 8);
            const top = Math.min(Math.max(8, lastY + 16), bh - th - 8);
            tooltip.style.left = left + 'px';
            tooltip.style.top = top + 'px';
        });
    });

    const navDetails = document.querySelectorAll('.navlinks details');

    navDetails.forEach((d) => {
        d.addEventListener('toggle', () => {
            if (!d.open) return;
            navDetails.forEach((other) => {
                if (other !== d && other.open) other.open = false;
            });
        });
    });

    document.addEventListener('click', (e) => {
        if (Array.from(navDetails).some((d) => d.contains(e.target))) return;

        navDetails.forEach((d) => {
            if (d.open) d.open = false;
        });
    });

    const buildTimeEl = document.querySelector('.build-time');
    const buildTime = new Date(buildTimeEl.dataset.time);

    buildTimeEl.textContent = formatRelativeTime(buildTime);
    setInterval(() => {
        buildTimeEl.textContent = formatRelativeTime(buildTime);
    }, 1000);

    function formatRelativeTime(time) {
        const now = new Date();
        const diff = time - now;
        const absDiff = Math.abs(diff);

        let relativeTime;
        if (absDiff < 60 * 1000) {
            relativeTime = `${Math.floor(absDiff / 1000)} second${Math.floor(absDiff / 1000) !== 1 ? 's' : ''}`;
            relativeTime = diff < 0 ? `${relativeTime} ago` : `in ${relativeTime}`;
        } else if (absDiff < 60 * 60 * 1000) {
            relativeTime = `${Math.floor(absDiff / (60 * 1000))} minute${Math.floor(absDiff / (60 * 1000)) !== 1 ? 's' : ''}`;
            relativeTime = diff < 0 ? `${relativeTime} ago` : `in ${relativeTime}`;
        } else if (absDiff < 24 * 60 * 60 * 1000) {
            relativeTime = `${Math.floor(absDiff / (60 * 60 * 1000))} hour${Math.floor(absDiff / (60 * 60 * 1000)) !== 1 ? 's' : ''}`;
            relativeTime = diff < 0 ? `${relativeTime} ago` : `in ${relativeTime}`;
        } else {
            relativeTime = `${Math.floor(absDiff / (24 * 60 * 60 * 1000))} day${Math.floor(absDiff / (24 * 60 * 60 * 1000)) !== 1 ? 's' : ''}`;
            relativeTime = diff < 0 ? `${relativeTime} ago` : `in ${relativeTime}`;
        }
        return relativeTime;
    }

    (async function () {
        const LANYARD_USER = '393694671383166998';
        const lanyard = `https://api.lanyard.rest/v1/users/${LANYARD_USER}`;
        const kvTextEl = document.querySelector('#kv-text');
        const root = document.querySelector('.discord');
        if (!root) return;

        const displayEl = root.querySelector('.display-name');
        const usernameEl = root.querySelector('.username');
        const statusEl = root.querySelector('.status');
        const activityEl = root.querySelector('.activity');
        const avatarEl = root.querySelector('.avatar');
        const colorDot = root.querySelector('.color-dot');

        const ACTIVITY_TYPE = ['Playing', 'Streaming to', 'Listening to', 'Watching', 'Custom status', 'Competing in'];
        const STATUS_COLOR = { online: '#4b8', idle: '#fa1', dnd: '#f44', offline: '#778' };

        const res = await fetch(lanyard);
        if (!res.ok) return;
        const j = await res.json();
        applyData(j.data);
        connectSocket();

        function escapeHtml(str) {
            return String(str).replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;').replace(/'/g, '&#39;');
        }

        function markdownToHtml(md) {
            if (!md) return '';
            let text = String(md);
            text = escapeHtml(text);

            text = text.replace(/!\[([^\]]*)\]\(([^)]+)\)/g, (m, alt, url) => {
                const src = escapeHtml(url.trim());
                const altText = escapeHtml(alt.trim());
                return `<img src="${src}" alt="${altText}" />`;
            });

            text = text.replace(/\[([^\]]+)\]\(([^)]+)\)/g, (m, label, url) => {
                const href = escapeHtml(url.trim());
                const lbl = escapeHtml(label.trim());
                return `<a href="${href}" target="_blank">${lbl}</a>`;
            });

            text = text.replace(/(^|[\s>])((https?:\/\/)[^\s<]+)/g, (m, pre, url) => {
                const href = escapeHtml(url);
                return `${pre}<a href="${href}" target="_blank">${href}</a>`;
            });

            text = text.replace(/\\n/g, '<br>');

            return text;
        }

        function applyData(d) {
            const u = d.discord_user;
            if (displayEl) displayEl.textContent = u.display_name || '';
            if (usernameEl) usernameEl.textContent = u.username;

            let actLabel = '';
            let actText = '';
            const a = d.activities.find((a) => a.type !== 4);
            if (a) {
                actLabel = ACTIVITY_TYPE[a.type];
                actText = a?.name;
            }

            statusEl.textContent = actText ? actLabel : d.discord_status || 'offline';
            activityEl.textContent = actText;
            activityEl.title = actText;
            avatarEl.style.backgroundImage = `url("https://chino.is-a.dev/cdn-cgi/image/format=avif/https://cdn.discordapp.com/avatars/${u.id}/${u.avatar}.webp?size=128")`;
            colorDot.style.background = STATUS_COLOR[d.discord_status] || STATUS_COLOR.offline;
            if (kvTextEl) {
                kvTextEl.innerHTML = markdownToHtml(d.kv.text);
            }
        }

        function connectSocket() {
            const ws = new WebSocket('wss://api.lanyard.rest/socket');
            ws.addEventListener('open', () => ws.send(JSON.stringify({ op: 2, d: { subscribe_to_id: LANYARD_USER } })));
            ws.addEventListener('error', () => ws.close());
            ws.addEventListener('close', () => setTimeout(connectSocket, 1000));
            ws.addEventListener('message', ({ data }) => {
                const { t, d } = JSON.parse(data);
                if (t !== 'INIT_STATE' && t !== 'PRESENCE_UPDATE') return;
                applyData(d);
            });
        }
    })();
</script>

<style is:global>
    :root {
        --bg: #111;
        --bg1a: #1116;
        --bg2: #222;
        --bg3: #333;
        --muted: #bbb;
        --text: #eee;
        --accent: #6f9;
        --word: #69e;
        --nav-height: 64px;
        color-scheme: only dark;
    }

    html,
    body {
        margin: 0;
        min-height: 100%;
        scrollbar-gutter: stable;
        touch-action: manipulation;
    }

    body {
        background: var(--bg);
        color: var(--text);
        line-height: 1.3;
        font-family: Inter, 'Segoe UI', Arial, system-ui, sans-serif;
    }

    a {
        color: var(--muted);
        text-decoration: none;

        &:hover {
            color: var(--text);
        }
    }

    button {
        font-family: inherit;
    }

    .tooltip {
        &.word {
            color: var(--word);
        }

        .tooltip-icon {
            display: inline-block;
            position: relative;
            vertical-align: middle;
            width: 1.25rem;
            height: 1.25rem;
            overflow: hidden;

            > img {
                position: absolute;
                top: 50%;
                left: 50%;
                transform: translate(-50%, -50%);
                width: 2.5rem;
                height: 2.5rem;
            }
        }

        .tooltip-text {
            display: none;
            position: absolute;
            z-index: 727;
            border-radius: 10px;
            background: var(--bg2);
            padding: 1rem;
            width: 400px;
            color: var(--text);
            font-weight: 400;

            img {
                vertical-align: middle;
                object-fit: cover;
                object-position: center;
            }
        }
        &:hover {
            .tooltip-text {
                display: block;
            }
        }
    }

    .indent {
        margin-left: 1rem !important;
    }

    @font-face {
        src: url('/font.woff2') format('woff2');
        font-family: Inter;
        font-display: swap;
    }
</style>

<style>
    nav {
        display: flex;
        position: sticky;
        top: 0;
        align-items: center;
        z-index: 727;
        backdrop-filter: blur(5px);
        margin: 0 auto;
        background: var(--bg1a);
        padding: 0 1rem;
        max-width: 1000px;
        height: var(--nav-height);
        white-space: nowrap;
        .logo {
            margin: 0;
            padding: 0.5rem;
            color: var(--accent);
            font-weight: 700;
            font-size: 1.5rem;
            text-decoration: none;
        }

        .navlinks {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin-left: auto;

            a {
                padding: 0.5rem 0.5rem;
            }

            details {
                position: relative;

                summary {
                    cursor: pointer;
                    padding: 0.5rem;
                    color: var(--muted);
                    list-style: none;

                    &::marker,
                    &::-webkit-details-marker {
                        display: none;
                    }

                    &:hover,
                    &:focus-visible {
                        color: var(--text);
                    }
                }

                &[open] {
                    summary {
                        color: var(--text);
                    }

                    div {
                        display: flex;
                        position: absolute;
                        top: calc(var(--nav-height) - 1rem);
                        right: 0;
                        flex-direction: column;
                        box-shadow: 0 12px 28px #0008;
                        border-radius: 10px;
                        background: var(--bg2);
                        padding: 0.25rem 0;
                        width: max-content;
                    }

                    a {
                        padding: 0.5rem 0.75rem;
                    }
                }
            }
        }
    }

    main {
        margin: auto;
        padding: 0 1rem;
        max-width: 1000px;
        min-height: calc(100dvh - 2 * var(--nav-height));
    }

    footer {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin: 0 auto;
        padding: 0 1rem;
        max-width: 1000px;
        height: var(--nav-height);
        color: var(--muted);
        .footer-right {
            p {
                margin: 0.25rem 0;
                text-align: right;
            }
        }

        .discord {
            > a {
                display: flex;
                gap: 0.5rem;
            }

            .avatar-wrapper {
                position: relative;
                width: 40px;
                height: 40px;
            }

            .avatar {
                border-radius: 8px;
                background-position: center;
                background-size: cover;
                background-repeat: no-repeat;
                width: 100%;
                height: 100%;
            }

            .name-row {
                width: max-content;
                min-width: 0;
                max-width: min(calc(100vw - 18rem), calc(1000px - 18rem));
                overflow: hidden;
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .display-name {
                color: var(--text);
                font-weight: 600;
            }

            .username {
                color: var(--muted);
                font-weight: 400;
            }

            .activity-row {
                width: max-content;
                min-width: 0;
                max-width: min(calc(100vw - 18rem), calc(1000px - 18rem));
                overflow: hidden;
                color: var(--muted);
                text-overflow: ellipsis;
                white-space: nowrap;
            }

            .activity {
                font-weight: 600;
            }

            .color-dot {
                position: absolute;
                right: 2px;
                bottom: 2px;
                border-radius: 50%;
                width: 0.7em;
                height: 0.7em;
            }
        }
    }
</style>
