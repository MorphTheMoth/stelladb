---
// @ts-nocheck
import { Image } from 'astro:assets';
import Layout from '@/layouts/Layout.astro';
import Page from '@/components/Page.astro';
import Tabs from '@/components/Tabs.astro';

export async function getStaticPaths() {
    const DATA_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/character.json';
    const UNRELEASED_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/unreleased.json';
    const ITEM_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/item.json';
    const WORD_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/word.json';

    const [data, unreleased, itemData, word] = await Promise.all([
        fetch(DATA_URL)
            .then((r) => r.json())
            .catch(() => ({})),
        fetch(UNRELEASED_URL)
            .then((r) => r.json())
            .catch(() => ({})),
        fetch(ITEM_URL)
            .then((r) => r.json())
            .catch(() => ({})),
        fetch(WORD_URL)
            .then((r) => r.json())
            .catch(() => ({})),
    ]);

    const both = Object.assign({}, data, unreleased);

    return Object.keys(both).map((id) => ({
        params: { id },
        props: { char: both[id], itemData, word },
    }));
}

const {
    params: { id },
    props: { char, itemData, word },
} = Astro;
const isUnreleased = /^\d+/.test(char.name);

if (char.tag[0] === char.class) {
    char.tag.shift();
}

const emoji = {
    Aqua: '💧',
    Ignis: '🔥',
    Terra: '⛰️',
    Ventus: '🌪️',
    Lux: '☀️',
    Umbra: '🌙',
    None: '⬜',
    Melee: '⚔️',
    Ranged: '🏹',
};

if (!char) {
    throw Astro.redirect('/404');
}
---

<Layout title={`${char.name} | stelladb`} image={isUnreleased ? undefined : `https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/head/head_${id}02_XL.webp`} description={`${char.star}⭐ ${char.element}${emoji[char.element]} ${char.class}${emoji[char.attackType]} ${char.tag.join(' ')}`}>
    <Page data-json={JSON.stringify(char)} data-item={JSON.stringify(itemData)} data-word={JSON.stringify(word)}>
        <Fragment slot="header">
            <h1>{char.name}</h1>
            <Tabs>
                <button data-tab="details" class="tab active">Details</button>
                <button data-tab="skills" class="tab">Skills</button>
                <button data-tab="potentials" class="tab">Potentials</button>
                <button data-tab="talents" class="tab">Talents</button>
                <button data-tab="gifts" class="tab">Gifts</button>
                <button data-tab="dates" class="tab">Dates</button>
            </Tabs>
        </Fragment>

        <Fragment slot="left">
            {!isUnreleased && <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/head/head_${id}02_XL.webp`} alt={char.name} title={char.name} width="256" height="340" densities={[1.25]} />}
            <div class="info">
                <p class="indent">
                    {`${char.star}⭐`}<br />
                    {char.element}{emoji[char.element]}<br />
                    {char.class}{emoji[char.attackType]}<br />
                    {
                        char.tag.map((tag) => (
                            <>
                                {tag}
                                <br />
                            </>
                        ))
                    }
                    🎤 {char.jpCv}<br />
                    🎂 {char.birthday}<br />
                </p>
                <a class="wiki" href={`https://stellasora.miraheze.org/wiki/${char.name.replace(/^\d{3}\s/, '').replaceAll(' ', '_')}`} target="_blank">Open in Wiki ↗</a>
            </div>
        </Fragment>

        <Fragment slot="right">
            <section id="details" class="tab-panel">
                <div class="slider-container">
                    <div class="slider upgrade1">
                        <label class="upgrade1-output">Upgrade: 8</label>
                        <input type="range" id="upgrade1" min="0" max="8" value="8" />
                    </div>

                    <div class="slider level">
                        <label class="level-output">Level: 90</label>
                        <input type="range" id="level" min="0" max="10" value="10" />
                    </div>
                </div>

                <div class="stats">
                    <h2>Stats</h2>
                    <div class="indent">
                        <p>
                            {
                                char.stat.length &&
                                    Object.entries(char.stat[97]).map(([stat, value]) => (
                                        <>
                                            {stat}: {value.toLocaleString('en-US')}
                                            <br />
                                        </>
                                    ))
                            }
                        </p>
                        <p>
                            {
                                Object.entries(char.fixedStat).map(([stat, value]) => (
                                    <>
                                        {stat}: {value.toLocaleString('en-US')}
                                        <br />
                                    </>
                                ))
                            }
                        </p>
                    </div>
                </div>

                <div class="upgrade-cost">
                    <h2>Next upgrade cost</h2>
                    <div class="indent">
                        <label class="cumulative checkbox"><input type="checkbox" id="cumulative-upgrade" /> Cumulative</label>
                        <label class="convert-to-tier-1 checkbox"><input type="checkbox" id="convert-to-tier-1-upgrade" /> Convert to Tier 1</label>
                        <div class="item-image">
                            {
                                char.upgrade.length &&
                                    Array.from(new Set(char.upgrade.flatMap((u) => (u ? Object.keys(u) : []))))
                                        .sort((a, b) => {
                                            const ida = Object.values(itemData).find((item) => item.name === a).id;
                                            const idb = Object.values(itemData).find((item) => item.name === b).id;
                                            if (ida === 1) return 1;
                                            if (idb === 1) return -1;
                                            return ida - idb;
                                        })
                                        .map((itemName) => {
                                            const item = Object.values(itemData).find((it) => it.name === itemName);
                                            if (!item) return null;
                                            return (
                                                <div style={`background: url('/${item.rarity}.avif') center/cover no-repeat; width: 52px; height: 52px; display: inline-block; padding: 4px;`}>
                                                    <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/item/item_${item.id}.webp`} alt={itemName} title={itemName} width="52" height="52" densities={[1.25]} />
                                                </div>
                                            );
                                        })
                            }
                        </div>
                        <p>
                            Max upgrade reached<br />
                            {
                                char.upgrade.length &&
                                    Object.entries(char.upgrade[7]).map(([item, amount]) => (
                                        <>
                                            {item}: {amount.toLocaleString('en-US')}
                                            <br />
                                        </>
                                    ))
                            }
                        </p>
                    </div>
                </div>
            </section>

            <section id="skills" class="tab-panel" hidden>
                <div class="slider-container">
                    <div class="slider upgrade2">
                        <label class="upgrade2-output">Upgrade: 0</label>
                        <input type="range" id="upgrade2" min="0" max="8" value="8" />
                    </div>
                    <div class="slider skill-level1">
                        <label class="skill-level1-output">Skill level: 1</label>
                        <input type="range" id="skill-level1" min="1" max="13" value="10" />
                    </div>
                </div>

                <div class="langtabs-wrapper" data-lang="EN">
                    <nav class="langtabs">
                        <button class="langtab active" data-lang="EN">EN</button>
                        <button class="langtab" data-lang="CN">CN</button>
                        <button class="langtab" data-lang="JP">JP</button>
                        <button class="langtab" data-lang="KR">KR</button>
                    </nav>
                </div>

                {!char.normalAtk && !char.skill && !char.supportSkill && !char.ultimate && <p class="indent">No data available</p>}

                {
                    char.normalAtk && (
                        <div class="normal-attack">
                            <div class="skill-header">
                                {!isUnreleased && <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/skill/${char.normalAtk.icon}.webp`} alt={char.normalAtk.name} title={char.normalAtk.name} width="64" height="64" densities={[1.25]} />}
                                <div>
                                    <h2>Normal attack: {char.normalAtk.name}</h2>
                                    <div>Energy Limit: {char.normalAtk.energyLimit}</div>
                                </div>
                            </div>
                            <div class="indent">
                                <p>{char.normalAtk.desc}</p>
                                {!char.normalAtk.damageType.length ? null : (
                                    <p class="small">
                                        Damage:{' '}
                                        {char.normalAtk.damageType.map((dt) => (
                                            <>
                                                {dt}
                                                <br />
                                            </>
                                        ))}
                                    </p>
                                )}
                                {!char.normalAtk.effectType.length ? null : <p class="small">Effect: {char.normalAtk.effectType.join(', ')}</p>}
                                {!char.normalAtk.addAttrType.length ? null : <p class="small">AddAttr: {char.normalAtk.addAttrType.join(', ')}</p>}
                                {!char.normalAtk.buffIcon.length ? null : <p class="small">Buff: {char.normalAtk.buffIcon.map((icon) => (icon === 'No Icon' ? 'No Icon' : <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${icon}.webp`} alt={icon} title={icon} width="26" height="36" densities={[1.25]} />)).reduce((prev, curr) => [prev, ' ', curr])}</p>}
                                {!char.normalAtk.effectData.length ? null : (
                                    <span class="tooltip small">
                                        hover this for effect data
                                        <div class="tooltip-text">
                                            {char.normalAtk.effectData.map((data) => (
                                                <>
                                                    {data}
                                                    <br />
                                                </>
                                            ))}
                                        </div>
                                    </span>
                                )}
                            </div>
                        </div>
                    )
                }

                {
                    char.skill && (
                        <div class="skill">
                            <div class="skill-header">
                                {!isUnreleased && <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/skill/${char.skill.icon}.webp`} alt={char.skill.name} title={char.skill.name} width="64" height="64" densities={[1.25]} />}
                                <div>
                                    <h2>Skill: {char.skill.name}</h2>
                                    <div>
                                        Cooldown: {char.skill.cooldown} • Energy Limit: {char.skill.energyLimit}
                                    </div>
                                </div>
                            </div>
                            <div class="indent">
                                <p>{char.skill.desc}</p>
                                {!char.skill.damageType.length ? null : (
                                    <p class="small">
                                        Damage:{' '}
                                        {char.skill.damageType.map((dt) => (
                                            <>
                                                {dt} <br />
                                            </>
                                        ))}
                                    </p>
                                )}
                                {!char.skill.effectType.length ? null : <p class="small">Effect: {char.skill.effectType.join(', ')}</p>}
                                {!char.skill.addAttrType.length ? null : <p class="small">AddAttr: {char.skill.addAttrType.join(', ')}</p>}
                                {!char.skill.buffIcon.length ? null : <p class="small">Buff: {char.skill.buffIcon.map((icon) => (icon === 'No Icon' ? 'No Icon' : <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${icon}.webp`} alt={icon} title={icon} width="26" height="36" densities={[1.25]} />)).reduce((prev, curr) => [prev, ' ', curr])}</p>}
                                {!char.skill.effectData.length ? null : (
                                    <span class="tooltip small">
                                        hover this for effect data
                                        <div class="tooltip-text">
                                            {char.skill.effectData.map((data) => (
                                                <>
                                                    {data}
                                                    <br />
                                                </>
                                            ))}
                                        </div>
                                    </span>
                                )}
                            </div>
                        </div>
                    )
                }

                {
                    char.supportSkill && (
                        <div class="support-skill">
                            <div class="skill-header">
                                {!isUnreleased && <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/skill/${char.supportSkill.icon}.webp`} alt={char.supportSkill.name} title={char.supportSkill.name} width="64" height="64" densities={[1.25]} />}
                                <div>
                                    <h2>Support skill: {char.supportSkill.name}</h2>
                                    <div>Cooldown: {char.supportSkill.cooldown}</div>
                                </div>
                            </div>
                            <div class="indent">
                                <p>{char.supportSkill.desc}</p>
                                {!char.supportSkill.damageType.length ? null : (
                                    <p class="small">
                                        Damage:{' '}
                                        {char.supportSkill.damageType.map((dt) => (
                                            <>
                                                {dt}
                                                <br />
                                            </>
                                        ))}
                                    </p>
                                )}
                                {!char.supportSkill.effectType.length ? null : <p class="small">Effect: {char.supportSkill.effectType.join(', ')}</p>}
                                {!char.supportSkill.addAttrType.length ? null : <p class="small">AddAttr: {char.supportSkill.addAttrType.join(', ')}</p>}
                                {!char.supportSkill.buffIcon.length ? null : <p class="small">Buff: {char.supportSkill.buffIcon.map((icon) => (icon === 'No Icon' ? 'No Icon' : <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${icon}.webp`} alt={icon} title={icon} width="26" height="36" densities={[1.25]} />)).reduce((prev, curr) => [prev, ' ', curr])}</p>}
                                {!char.supportSkill.effectData.length ? null : (
                                    <span class="tooltip small">
                                        hover this for effect data
                                        <div class="tooltip-text">
                                            {char.supportSkill.effectData.map((data) => (
                                                <>
                                                    {data}
                                                    <br />
                                                </>
                                            ))}
                                        </div>
                                    </span>
                                )}
                            </div>
                        </div>
                    )
                }

                {
                    char.ultimate && (
                        <div class="ultimate">
                            <div class="skill-header">
                                {!isUnreleased && <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/skill/${char.ultimate.icon}.webp`} alt={char.ultimate.name} title={char.ultimate.name} width="64" height="64" densities={[1.25]} />}
                                <div>
                                    <h2>Ultimate: {char.ultimate.name}</h2>
                                    <div>
                                        Cooldown: {char.ultimate.cooldown} • Energy: {char.ultimate.energy}
                                    </div>
                                </div>
                            </div>
                            <div class="indent">
                                <p>{char.ultimate.desc}</p>
                                {!char.ultimate.damageType.length ? null : (
                                    <p class="small">
                                        Damage:{' '}
                                        {char.ultimate.damageType.map((dt) => (
                                            <>
                                                {dt}
                                                <br />
                                            </>
                                        ))}
                                    </p>
                                )}
                                {!char.ultimate.effectType.length ? null : <p class="small">Effect: {char.ultimate.effectType.join(', ')}</p>}
                                {!char.ultimate.addAttrType.length ? null : <p class="small">AddAttr: {char.ultimate.addAttrType.join(', ')}</p>}
                                {!char.ultimate.buffIcon.length ? null : <p class="small">Buff: {char.ultimate.buffIcon.map((icon) => (icon === 'No Icon' ? 'No Icon' : <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${icon}.webp`} alt={icon} title={icon} width="26" height="36" densities={[1.25]} />)).reduce((prev, curr) => [prev, ' ', curr])}</p>}
                                {!char.ultimate.effectData.length ? null : (
                                    <span class="tooltip small">
                                        hover this for effect data
                                        <div class="tooltip-text">
                                            {char.ultimate.effectData.map((data) => (
                                                <>
                                                    {data}
                                                    <br />
                                                </>
                                            ))}
                                        </div>
                                    </span>
                                )}
                            </div>
                        </div>
                    )
                }

                {
                    char.special && (
                        <div class="special">
                            <h2>Special: {char.special.name}</h2>
                            <div class="indent">
                                <p>Type: {char.special.type}</p>
                                <p>Params: {char.special.params}</p>
                                <p class="small">Damage: {char.special.damageType}</p>
                            </div>
                        </div>
                    )
                }

                <div class="skill-upgrade-cost">
                    <h2>Next skill upgrade cost</h2>
                    <div class="indent">
                        <label class="cumulative checkbox"><input type="checkbox" id="cumulative-skill" /> Cumulative</label>
                        <label class="convert-to-tier-1 checkbox"><input type="checkbox" id="convert-to-tier-1-skill" /> Convert to Tier 1</label>
                        <div class="item-image">
                            {
                                char.skillUpgrade.length &&
                                    Array.from(new Set(char.skillUpgrade.flatMap((u) => (u ? Object.keys(u) : []))))
                                        .sort((a, b) => {
                                            const ida = Object.values(itemData).find((item) => item.name === a).id;
                                            const idb = Object.values(itemData).find((item) => item.name === b).id;
                                            if (ida === 1) return 1;
                                            if (idb === 1) return -1;
                                            return ida - idb;
                                        })
                                        .map((itemName) => {
                                            const item = Object.values(itemData).find((it) => it.name === itemName);
                                            if (!item) return null;
                                            return (
                                                <div style={`background: url('/${item.rarity}.avif') center/cover no-repeat; width: 52px; height: 52px; display: inline-block; padding: 4px;`}>
                                                    <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/item/item_${item.id}.webp`} alt={itemName} title={itemName} width="52" height="52" densities={[1.25]} />
                                                </div>
                                            );
                                        })
                            }
                        </div>
                        <p>
                            Max upgrade reached<br />
                            {
                                char.skillUpgrade.length &&
                                    Object.entries(char.skillUpgrade[8]).map(([item, amount]) => (
                                        <>
                                            {item}: {amount.toLocaleString('en-US')}
                                            <br />
                                        </>
                                    ))
                            }
                        </p>
                    </div>
                </div>
            </section>

            <section id="potentials" class="tab-panel" hidden>
                <div class="slider-container">
                    <div class="slider potential-level">
                        <label class="potential-level-output">Potential level: 1</label>
                        <input type="range" id="potential-level" min="1" max="9" value="6" />
                    </div>
                    <div class="slider skill-level2">
                        <label class="skill-level2-output">Skill level: 1</label>
                        <input type="range" id="skill-level2" min="1" max="13" value="10" />
                    </div>
                </div>

                <div class="langtabs-wrapper" data-lang="EN">
                    <nav class="langtabs">
                        <button class="langtab active" data-lang="EN">EN</button>
                        <button class="langtab" data-lang="CN">CN</button>
                        <button class="langtab" data-lang="JP">JP</button>
                        <button class="langtab" data-lang="KR">KR</button>
                    </nav>
                </div>

                <h2>Main core</h2>
                {
                    char.potential.mainCore?.length &&
                        char.potential.mainCore.map((pot) => (
                            <div class="potential-wrapper">
                                {!isUnreleased && <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/potential/${pot.id}.webp`} alt={pot.name} title={pot.name} width="120" height="153" densities={[1.25]} />}
                                <div class="potential" data-potential={JSON.stringify(pot)}>
                                    <h3>
                                        {pot.id % 100}. {pot.name}
                                    </h3>
                                    <div class="indent">
                                        <p>{pot.desc}</p>
                                        {!pot.damageType.length ? null : (
                                            <p class="small">
                                                Damage:{' '}
                                                {pot.damageType.map((dt) => (
                                                    <>
                                                        {dt}
                                                        <br />
                                                    </>
                                                ))}
                                            </p>
                                        )}
                                        {!pot.effectType.length ? null : <p class="small">Effect: {pot.effectType.join(', ')}</p>}
                                        {!pot.addAttrType.length ? null : <p class="small">AddAttr: {pot.addAttrType.join(', ')}</p>}
                                        {!pot.buffIcon.length ? null : <p class="small">Buff: {pot.buffIcon.map((icon) => (icon === 'No Icon' ? 'No Icon' : <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${icon}.webp`} alt={icon} title={icon} width="26" height="36" densities={[1.25]} />)).reduce((prev, curr) => [prev, ' ', curr])}</p>}
                                        {!pot.effectData.length ? null : (
                                            <span class="tooltip small">
                                                hover this for effect data
                                                <div class="tooltip-text">
                                                    {pot.effectData.map((data) => (
                                                        <>
                                                            {data}
                                                            <br />
                                                        </>
                                                    ))}
                                                </div>
                                            </span>
                                        )}
                                    </div>
                                </div>
                            </div>
                        ))
                }
                <h2>Main normal</h2>
                {
                    char.potential.mainNormal?.length &&
                        char.potential.mainNormal.map((pot) => (
                            <div class="potential-wrapper">
                                {!isUnreleased && <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/potential/${pot.id}.webp`} alt={pot.name} title={pot.name} width="120" height="153" densities={[1.25]} />}
                                <div class="potential" data-potential={JSON.stringify(pot)}>
                                    <h3>
                                        {pot.id % 100}. {pot.name}
                                    </h3>
                                    <div class="indent">
                                        <p>{pot.desc}</p>
                                        {!pot.damageType.length ? null : (
                                            <p class="small">
                                                Damage:{' '}
                                                {pot.damageType.map((dt) => (
                                                    <>
                                                        {dt}
                                                        <br />
                                                    </>
                                                ))}
                                            </p>
                                        )}
                                        {!pot.effectType.length ? null : <p class="small">Effect: {pot.effectType.join(', ')}</p>}
                                        {!pot.addAttrType.length ? null : <p class="small">AddAttr: {pot.addAttrType.join(', ')}</p>}
                                        {!pot.buffIcon.length ? null : <p class="small">Buff: {pot.buffIcon.map((icon) => (icon === 'No Icon' ? 'No Icon' : <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${icon}.webp`} alt={icon} title={icon} width="26" height="36" densities={[1.25]} />)).reduce((prev, curr) => [prev, ' ', curr])}</p>}
                                        {!pot.effectData.length ? null : (
                                            <span class="tooltip small">
                                                hover this for effect data
                                                <div class="tooltip-text">
                                                    {pot.effectData.map((data) => (
                                                        <>
                                                            {data}
                                                            <br />
                                                        </>
                                                    ))}
                                                </div>
                                            </span>
                                        )}
                                    </div>
                                </div>
                            </div>
                        ))
                }
                <h2>Common</h2>
                {
                    char.potential.common?.length &&
                        char.potential.common.map((pot) => (
                            <div class="potential-wrapper">
                                {!isUnreleased && <Image src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/potential/${pot.id}.webp`} alt={pot.name} title={pot.name} width="120" height="153" densities={[1.25]} />}
