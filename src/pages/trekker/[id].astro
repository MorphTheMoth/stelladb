    <script>
        // @ts-nocheck
        const char = JSON.parse(document.querySelector('.page').dataset.json);
        const itemData = JSON.parse(document.querySelector('.page').dataset.item);
        const word = JSON.parse(document.querySelector('.page').dataset.word);

        function format(desc) {
            return desc
                .replace(/<color=#(.{6})>/g, '<color style="color:#$1">')
                .replace(/\u000b/g, '<br />')
                .replace(/##([^#]*?)#(\d{1,4})#/g, (match, name, id) => {
                    const wordName = word[id].name;
                    let wordDesc = word[id].desc;

                    word[id].params.forEach((param, index) => {
                        wordDesc = wordDesc.replaceAll(`&Param${index + 1}&`, param);
                    });

                    wordDesc = wordDesc.replace(/<color=#(.{6})>/g, '<color style="color:#$1">').replace(/\u000b/g, '<br />');

                    return `<span class="tooltip word">
                        ${wordName}
                        ${word[id].icon ? `<span class="tooltip-icon"><img src="https://chino.is-a.dev/cdn-cgi/image/format=avif/https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/zzzother/${word[id].icon}.webp" alt="${wordName}" title="${wordName}"/></span>` : ''}
                        <div class="tooltip-text">
                            <b>${wordName}</b><br />
                            <p>${wordDesc}</p>
                        </div>
                    </span>`;
                })
                .replace(/#(\d{1,4})#([^#]*?)##/g, (match, id, name) => {
                    const wordName = word[id].name;
                    let wordDesc = word[id].desc;

                    word[id].params.forEach((param, index) => {
                        wordDesc = wordDesc.replaceAll(`&Param${index + 1}&`, param);
                    });

                    wordDesc = wordDesc.replace(/<color=#(.{6})>/g, '<color style="color:#$1">').replace(/\u000b/g, '<br />');

                    return `<span class="tooltip word">
                        ${wordName}
                        ${word[id].icon ? `<span class="tooltip-icon"><img src="https://chino.is-a.dev/cdn-cgi/image/format=avif/https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/zzzother/${word[id].icon}.webp" alt="${wordName}" title="${wordName}"/></span>` : ''}
                        <div class="tooltip-text">
                            <b>${wordName}</b><br />
                            <p>${wordDesc}</p>
                        </div>
                    </span>`;
                });
        }

        const upgrade1Input = document.querySelector('#upgrade1');
        const upgrade1Output = document.querySelector('.upgrade1-output');
        const levelInput = document.querySelector('#level');
        const levelOutput = document.querySelector('.level-output');
        const stats = document.querySelector('.stats p');
        const upgradeCost = document.querySelector('.upgrade-cost p');
        const upgradeCostItemImage = document.querySelector('.upgrade-cost .item-image');
        const cumulativeUpgrade = document.querySelector('#cumulative-upgrade');
        const convertToTier1Upgrade = document.querySelector('#convert-to-tier-1-upgrade');

        let upgrade1;
        let level;

        upgrade1Input.addEventListener('input', onDetailsInput);
        levelInput.addEventListener('input', onDetailsInput);
        cumulativeUpgrade.addEventListener('change', onDetailsInput);
        convertToTier1Upgrade.addEventListener('change', onDetailsInput);
        onDetailsInput();

        function onDetailsInput() {
            upgrade1 = +upgrade1Input.value;
            level = +upgrade1Input.value * 10 + +levelInput.value;

            if (level < 1) level = 1;
            if (level > 90) level = 90;

            upgrade1Output.innerHTML = `Upgrade: ${upgrade1}`;
            levelOutput.innerHTML = `Level: ${level}`;
            if (char.stat.length) {
                stats.innerHTML = Object.entries(char.stat[level + upgrade1 - 1])
                    .map(([stat, value]) => `${stat}: ${value.toLocaleString('en-US')}`)
                    .join('<br />');
            }
            if (upgrade1 >= 7) upgrade1 = 7;

            let totals = {};
            if (char.upgrade.length) {
                if (cumulativeUpgrade.checked) {
                    if (convertToTier1Upgrade.checked) {
                        for (let i = 0; i <= upgrade1; i++) {
                            Object.entries(char.upgrade[i]).forEach(([item, amount]) => {
                                const itemInfo = Object.values(itemData).find((it) => it.name === item);
                                if (itemInfo.type === 'CharacterLimitBreak') {
                                    const tier1Item = Object.values(itemData).find((it) => it.type === 'CharacterLimitBreak' && it.rarity === 'M' && it.id.toString() === `${itemInfo.id.toString().slice(0, -1)}1`);
                                    if (itemInfo.rarity === 'R') {
                                        totals[tier1Item.name] = (totals[tier1Item.name] || 0) + amount * 3;
                                    } else if (itemInfo.rarity === 'SR') {
                                        totals[tier1Item.name] = (totals[tier1Item.name] || 0) + amount * 9;
                                    } else {
                                        totals[item] = (totals[item] || 0) + amount;
                                    }
                                } else {
                                    totals[item] = (totals[item] || 0) + amount;
                                }
                            });
                        }
                    } else {
                        for (let i = 0; i <= upgrade1; i++) {
                            Object.entries(char.upgrade[i]).forEach(([item, amount]) => {
                                totals[item] = (totals[item] || 0) + amount;
                            });
                        }
                    }
                } else {
                    if (convertToTier1Upgrade.checked) {
                        Object.entries(char.upgrade[upgrade1]).forEach(([item, amount]) => {
                            const itemInfo = Object.values(itemData).find((it) => it.name === item);
                            if (itemInfo.type === 'CharacterLimitBreak') {
                                const tier1Item = Object.values(itemData).find((it) => it.type === 'CharacterLimitBreak' && it.rarity === 'M' && it.id.toString() === `${itemInfo.id.toString().slice(0, -1)}1`);
                                if (itemInfo.rarity === 'R') {
                                    totals[tier1Item.name] = (totals[tier1Item.name] || 0) + amount * 3;
                                } else if (itemInfo.rarity === 'SR') {
                                    totals[tier1Item.name] = (totals[tier1Item.name] || 0) + amount * 9;
                                } else {
                                    totals[item] = (totals[item] || 0) + amount;
                                }
                            } else {
                                totals[item] = (totals[item] || 0) + amount;
                            }
                        });
                    } else {
                        Object.entries(char.upgrade[upgrade1]).forEach(([item, amount]) => {
                            totals[item] = (totals[item] || 0) + amount;
                        });
                    }
                }
            }

            const sorted = sortByItemId(totals);
            const sortedNames = sorted.map(([itemName]) => itemName);

            upgradeCost.innerHTML = sorted.map(([item, amount]) => `${item}: ${amount.toLocaleString('en-US')}<br />`).join('');
            if (+upgrade1Input.value > 7) upgradeCost.innerHTML = 'Max upgrade reached<br />' + upgradeCost.innerHTML;
            upgradeCostItemImage.querySelectorAll('div').forEach((div) => {
                const itemName = div.querySelector('img').alt;
                div.style.display = sortedNames.includes(itemName) ? 'inline-block' : 'none';
            });
        }

        function sortByItemId(totals) {
            return Object.entries(totals).sort((a, b) => {
                const ida = Object.values(itemData).find((item) => item.name === a[0]).id;
                const idb = Object.values(itemData).find((item) => item.name === b[0]).id;
                if (ida === 1) return 1;
                if (idb === 1) return -1;
                return ida - idb;
            });
        }

        const upgrade2Input = document.querySelector('#upgrade2');
        const upgrade2Output = document.querySelector('.upgrade2-output');
        const skillLevel1Input = document.querySelector('#skill-level1');
        const skillLevel1Output = document.querySelector('.skill-level1-output');
        const normalAttackName = document.querySelector('.normal-attack h2');
        const normalAttack = document.querySelector('.normal-attack p');
        const skillName = document.querySelector('.skill h2');
        const skill = document.querySelector('.skill p');
        const supportSkillName = document.querySelector('.support-skill h2');
        const supportSkill = document.querySelector('.support-skill p');
        const ultimateName = document.querySelector('.ultimate h2');
        const ultimate = document.querySelector('.ultimate p');
        const skillUpgradeCost = document.querySelector('.skill-upgrade-cost p');
        const skillUpgradeItemImage = document.querySelector('.skill-upgrade-cost .item-image');
        const cumulativeSkill = document.querySelector('#cumulative-skill');
        const convertToTier1Skill = document.querySelector('#convert-to-tier-1-skill');
        const skillLangInput = document.querySelector('#skills .langtabs-wrapper');

        let upgrade2;
        let skillLevel;
        let skillLang;

        upgrade2Input.addEventListener('input', onSkillsInput);
        skillLevel1Input.addEventListener('input', onSkillsInput);
        cumulativeSkill.addEventListener('change', onSkillsInput);
        convertToTier1Skill.addEventListener('change', onSkillsInput);
        skillLangInput.addEventListener('click', (e) => {
            if (e.target.classList.contains('langtab')) {
                skillLangInput.querySelectorAll('.langtab').forEach((btn) => btn.classList.remove('active'));
                e.target.classList.add('active');
                skillLangInput.dataset.lang = e.target.dataset.lang;
                onSkillsInput();
            }
        });
        onSkillsInput();

        function onSkillsInput() {
            upgrade2 = +upgrade2Input.value;
            skillLevel = +skillLevel1Input.value;
            skillLang = skillLangInput.dataset.lang;

            if (skillLevel < 1) skillLevel = 1;
            if (skillLevel > 13) skillLevel = 13;

            upgrade2Output.innerHTML = `Upgrade: ${upgrade2}`;
            skillLevel1Output.innerHTML = `Skill level: ${skillLevel}`;
            const nameLang = `name${skillLang === 'EN' ? '' : skillLang}`;
            const descLang = `desc${skillLang === 'EN' ? '' : skillLang}`;
            normalAttackName.innerHTML = `Normal attack: ${char.normalAtk[nameLang]}`;
            skillName.innerHTML = `Skill: ${char.skill[nameLang]}`;
            supportSkillName.innerHTML = `Support Skill: ${char.supportSkill[nameLang]}`;
            ultimateName.innerHTML = `Ultimate: ${char.ultimate[nameLang]}`;

            normalAttack.innerHTML = replaceSkillParams(char.normalAtk[descLang], char.normalAtk.params, char.normalAtk.paramsTooltips, upgrade2, skillLevel);
            skill.innerHTML = replaceSkillParams(char.skill[descLang], char.skill.params, char.skill.paramsTooltips, upgrade2, skillLevel);
            supportSkill.innerHTML = replaceSkillParams(char.supportSkill[descLang], char.supportSkill.params, char.supportSkill.paramsTooltips, upgrade2, skillLevel);
            ultimate.innerHTML = replaceSkillParams(char.ultimate[descLang], char.ultimate.params, char.ultimate.paramsTooltips, upgrade2, skillLevel);

            if (skillLevel >= 9) skillLevel = 9;

            let totals = {};
            if (char.skillUpgrade.length) {
                if (cumulativeSkill.checked) {
                    if (convertToTier1Skill.checked) {
                        for (let i = 0; i <= skillLevel - 1; i++) {
                            Object.entries(char.skillUpgrade[i]).forEach(([item, amount]) => {
                                const itemInfo = Object.values(itemData).find((it) => it.name === item);
                                if (itemInfo.type === 'SkillStrengthen') {
                                    const tier1Item = Object.values(itemData).find((it) => it.type === 'SkillStrengthen' && it.rarity === 'M' && it.id.toString() === `${itemInfo.id.toString().slice(0, -1)}1`);
                                    if (itemInfo.rarity === 'R') {
                                        totals[tier1Item.name] = (totals[tier1Item.name] || 0) + amount * 3;
                                    } else if (itemInfo.rarity === 'SR') {
                                        totals[tier1Item.name] = (totals[tier1Item.name] || 0) + amount * 9;
                                    } else {
                                        totals[item] = (totals[item] || 0) + amount;
                                    }
                                } else {
                                    totals[item] = (totals[item] || 0) + amount;
                                }
                            });
                        }
                    } else {
                        for (let i = 0; i <= skillLevel - 1; i++) {
                            Object.entries(char.skillUpgrade[i]).forEach(([item, amount]) => {
                                totals[item] = (totals[item] || 0) + amount;
                            });
                        }
                    }
                } else {
                    if (convertToTier1Skill.checked) {
                        Object.entries(char.skillUpgrade[skillLevel - 1]).forEach(([item, amount]) => {
                            const itemInfo = Object.values(itemData).find((it) => it.name === item);
                            if (itemInfo.type === 'SkillStrengthen') {
                                const tier1Item = Object.values(itemData).find((it) => it.type === 'SkillStrengthen' && it.rarity === 'M' && it.id.toString() === `${itemInfo.id.toString().slice(0, -1)}1`);
                                if (itemInfo.rarity === 'R') {
                                    totals[tier1Item.name] = (totals[tier1Item.name] || 0) + amount * 3;
                                } else if (itemInfo.rarity === 'SR') {
                                    totals[tier1Item.name] = (totals[tier1Item.name] || 0) + amount * 9;
                                } else {
                                    totals[item] = (totals[item] || 0) + amount;
                                }
                            } else {
                                totals[item] = (totals[item] || 0) + amount;
                            }
                        });
                    } else {
                        Object.entries(char.skillUpgrade[skillLevel - 1]).forEach(([item, amount]) => {
                            totals[item] = (totals[item] || 0) + amount;
                        });
                    }
                }
            }

            const sorted = sortByItemId(totals);
            const sortedNames = sorted.map(([itemName]) => itemName);

            skillUpgradeCost.innerHTML = sorted.map(([item, amount]) => `${item}: ${amount.toLocaleString('en-US')}<br />`).join('');
            if (+skillLevel1Input.value > 9) skillUpgradeCost.innerHTML = 'Max upgrade reached<br />' + skillUpgradeCost.innerHTML;
            skillUpgradeItemImage.querySelectorAll('div').forEach((div) => {
                const itemName = div.querySelector('img').alt;
                div.style.display = sortedNames.includes(itemName) ? 'inline-block' : 'none';
            });
        }

        function replaceSkillParams(desc, params, tooltips, upgrade, level) {
            let result = desc;

            params.forEach((paramSet, index) => {
                const splitted = paramSet.toString().split('/');
                const paramValue = splitted.length === 13 ? splitted[skillLevel - 1] : splitted.length === 9 ? splitted[upgrade2] : splitted[0];
                const tooltip = tooltips[index];
                const tooltipContent = `
                    ${!tooltip.damageType ? '' : `Damage: ${tooltip.damageType}<br />`}
                    ${!tooltip.effectType ? '' : `Effect: ${tooltip.effectType}<br />`}
                    ${!tooltip.addAttrType ? '' : `AddAttr: ${tooltip.addAttrType}<br />`}
                    ${!tooltip.buffIcon ? '' : `Buff: ${tooltip.buffIcon === 'No Icon' ? 'No Icon' : `<img src="https://chino.is-a.dev/cdn-cgi/image/format=avif/https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${tooltip.buffIcon}.webp" alt="${tooltip.buffIcon}" title="${tooltip.buffIcon}" width="26" height="36" />`}<br />`}
                `.trim();
                result = result.replaceAll(`&Param${index + 1}&`, !tooltipContent ? paramValue : `<span class="tooltip">${paramValue}<span class="tooltip-text">${tooltipContent}</span></span>`);
            });

            return format(result);
        }

        const potentialLevelInput = document.querySelector('#potential-level');
        const potentialLevelOutput = document.querySelector('.potential-level-output');
        const skillLevel2Input = document.querySelector('#skill-level2');
        const skillLevel2Output = document.querySelector('.skill-level2-output');
        const potentialElements = document.querySelectorAll('.potential');
        const potentialLangInput = document.querySelector('#potentials .langtabs-wrapper');

        let potentialLevel;
        let skillLevel2;
        let potentialLang;

        potentialLevelInput.addEventListener('input', onPotentialsInput);
        skillLevel2Input.addEventListener('input', onPotentialsInput);
        potentialLangInput.addEventListener('click', (e) => {
            if (e.target.classList.contains('langtab')) {
                potentialLangInput.querySelectorAll('.langtab').forEach((btn) => btn.classList.remove('active'));
                e.target.classList.add('active');
                potentialLangInput.dataset.lang = e.target.dataset.lang;
                onPotentialsInput();
            }
        });
        onPotentialsInput();

        function onPotentialsInput() {
            potentialLevel = +potentialLevelInput.value;
            skillLevel2 = +skillLevel2Input.value;
            potentialLang = potentialLangInput.dataset.lang;

            potentialLevelOutput.innerHTML = `Potential level: ${potentialLevel}`;
            skillLevel2Output.innerHTML = `Skill level: ${skillLevel2}`;
            potentialElements.forEach((e) => {
                const pot = JSON.parse(e.dataset.potential);
                const nameLang = `name${potentialLang === 'EN' ? '' : potentialLang}`;
                const descLang = `desc${potentialLang === 'EN' ? '' : potentialLang}`;

                let result = pot[descLang];

                pot.params.forEach((paramSet, index) => {
                    const splitted = paramSet.toString().split('/');
                    const paramValue = splitted.length === 13 ? splitted[skillLevel2 - 1] : splitted.length === 9 ? splitted[potentialLevel - 1] : splitted[0];
                    const tooltip = pot.paramsTooltips[index];
                    const tooltipContent = `
                        ${!tooltip.damageType ? '' : `Damage: ${tooltip.damageType}<br />`}
                        ${!tooltip.effectType ? '' : `Effect: ${tooltip.effectType}<br />`}
                        ${!tooltip.addAttrType ? '' : `AddAttr: ${tooltip.addAttrType}<br />`}
                        ${!tooltip.buffIcon ? '' : `Buff: ${tooltip.buffIcon === 'No Icon' ? 'No Icon' : `<img src="https://chino.is-a.dev/cdn-cgi/image/format=avif/https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${tooltip.buffIcon}.webp" alt="${tooltip.buffIcon}" title="${tooltip.buffIcon}" width="26" height="36" />`}<br />`}
                    `.trim();
                    result = result.replaceAll(`&Param${index + 1}&`, !tooltipContent ? paramValue : `<span class="tooltip">${paramValue}<span class="tooltip-text">${tooltipContent}</span></span>`);
                });

                pot.hiddenParams.forEach((paramSet, index) => {
                    const splitted = paramSet.toString().split('/');
                    const paramValue = splitted.length === 13 ? splitted[skillLevel2 - 1] : splitted.length === 9 ? splitted[potentialLevel - 1] : splitted[0];
                    const tooltip = pot.hiddenParamsTooltips[index];
                    const tooltipContent = `
                        ${!tooltip.damageType ? '' : `Damage: ${tooltip.damageType}<br />`}
                        ${!tooltip.effectType ? '' : `Effect: ${tooltip.effectType}<br />`}
                        ${!tooltip.addAttrType ? '' : `AddAttr: ${tooltip.addAttrType}<br />`}
                        ${!tooltip.buffIcon ? '' : `Buff: ${tooltip.buffIcon === 'No Icon' ? 'No Icon' : `<img src="https://chino.is-a.dev/cdn-cgi/image/format=avif/https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${tooltip.buffIcon}.webp" alt="${tooltip.buffIcon}" title="${tooltip.buffIcon}" width="26" height="36" />`}<br />`}
                    `.trim();
                    result = result.replaceAll(`&HiddenParam${index + 1}&`, !tooltipContent ? paramValue : `<span class="tooltip">${paramValue}<span class="tooltip-text">${tooltipContent}</span></span>`);
                });

                e.querySelector('h3').innerHTML = `${pot.id % 100}. ${pot[nameLang]}`;
                e.querySelector('p').innerHTML = format(result);
            });
        }

        const talentNameElements = document.querySelectorAll('.talent h2');
        const talentElements = document.querySelectorAll('.talent p:first-of-type');
        const talentLangInput = document.querySelector('#talents .langtabs-wrapper');

        let talentLang;
        talentLangInput.addEventListener('click', (e) => {
            if (e.target.classList.contains('langtab')) {
                talentLangInput.querySelectorAll('.langtab').forEach((btn) => btn.classList.remove('active'));
                e.target.classList.add('active');
                talentLangInput.dataset.lang = e.target.dataset.lang;
                onTalentsInput();
            }
        });
        onTalentsInput();

        function onTalentsInput() {
            talentLang = talentLangInput.dataset.lang;

            talentElements.forEach((e, i) => {
                const talent = char.talent[i];
                const params = talent.boost[0].params;
                const nameLang = `name${talentLang === 'EN' ? '' : talentLang}`;
                const descLang = `desc${talentLang === 'EN' ? '' : talentLang}`;
                const name = talent.boost[0][nameLang];
                let desc = talent.boost[0][descLang];

                params.forEach((param, index) => {
                    const tooltip = talent.boost[0].paramsTooltips[index];
                    const tooltipContent = `
                    ${!tooltip.damageType ? '' : `Damage: ${tooltip.damageType}<br />`}
                    ${!tooltip.effectType ? '' : `Effect: ${tooltip.effectType}<br />`}
                    ${!tooltip.addAttrType ? '' : `AddAttr: ${tooltip.addAttrType}<br />`}
                    ${!tooltip.buffIcon ? '' : `Buff: ${tooltip.buffIcon === 'No Icon' ? 'No Icon' : `<img src="https://chino.is-a.dev/cdn-cgi/image/format=avif/https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/buff/${tooltip.buffIcon}.webp" alt="${tooltip.buffIcon}" title="${tooltip.buffIcon}" width="26" height="36" />`}<br />`}
                `.trim();
                    desc = desc.replaceAll(`&Param${index + 1}&`, !tooltipContent ? param : `<span class="tooltip">${param}<span class="tooltip-text">${tooltipContent}</span></span>`);
                });

                talentNameElements[i].innerHTML = `${i + 1}. ${name}`;
                talentElements[i].innerHTML = format(desc);
            });
        }

        const talentBonusStat = document.querySelector('.talent-bonus-stat p');

        let bonusStatResult = '';

        char.talent[0].boost.slice(1).forEach((boost, i) => {
            if ([6, 7, 8, 9, 10].includes(i + 1)) return;

            let desc = boost.desc;

            boost.params.forEach((param, index) => {
                param = param.toString();
                if ([1, 2, 3, 4, 5].includes(i + 1)) {
                    if (param.includes('%')) {
                        param = parseFloat(param) * 2 + '%';
                    } else {
                        param = parseFloat(param) * 2;
                    }
                }
                desc = desc
                    .replaceAll(`&Param${index + 1}&`, param)
                    .replaceAll('Increases ', '')
                    .replaceAll('Base ', '')
                    .replaceAll('by ', '+')
                    .replace(/\.$/, '');
            });

            bonusStatResult += `${format(desc)}<br />`;
        });

        talentBonusStat.innerHTML = bonusStatResult;
    </script>

    <style>
        .skill-header h2 {
            margin: 0;
        }

        .potential-wrapper {
            display: flex;
            align-items: center;
            gap: 1rem;
        }

        .potential-wrapper > img {
            margin: 10px 0;
        }

        .date {
            display: flex;
            align-items: center;
            gap: 1rem;
            margin: 1rem 0;

            h2 {
                margin: 0;
            }
        }

        p:not(.small) {
            margin: 0.5rem 0;
        }
    </style>
</Layout>
