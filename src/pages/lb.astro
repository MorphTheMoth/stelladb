---
// @ts-nocheck
import Card from '@/components/Card.astro';
import SearchableGrid from '@/components/SearchableGrid.astro';
import Layout from '@/layouts/Layout.astro';

const DATA_URL = 'https://raw.githubusercontent.com/AutumnVN/ssleaderboard/refs/heads/main/meta.json';

const data = await fetch(DATA_URL)
    .then((r) => r.json())
    .catch(() => ({}));
---

<Layout title="Leaderboard | stelladb">
    <SearchableGrid placeholder="Search leaderboard by id, name or boss name..." noResultsText="No leaderboard found.">
        {
            Object.entries(data).map(([id, data]) => {
                const isBB = /^bb/.test(id);
                const season = id.match(/\d+/)?.[0];
                const name = isBB ? `Boss Blitz S${season}` : `Finale Echoing S${season}`;
                const floors = data.floor;
                const desc = Object.values(floors)
                    .map((f) => f.name)
                    .join(', ');
                const firstIcon = Object.values(floors)[0]?.icon;

                return (
                    <div class={'card-item'} data-id={id} data-name={name} data-desc={desc}>
                        <Card href={`/lb/${id}`} name={name} desc={desc} image={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/${isBB ? 'mapchallenge' : 'monster'}/${firstIcon}.webp`} inset={-30} />
                    </div>
                );
            })
        }
    </SearchableGrid>
</Layout>
