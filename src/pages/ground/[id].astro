---
// @ts-nocheck
import Layout from '@/layouts/Layout.astro';
import Tabs from '@/components/Tabs.astro';

export async function getStaticPaths() {
    const DATA_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/ground.json';
    const data = await fetch(DATA_URL).then((res) => res.json());

    return Object.keys(data).map((id) => ({
        params: { id },
    }));
}

const DATA_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/ground.json';

const { params } = Astro;
const id = params.id;

const data = await fetch(DATA_URL).then((res) => res.json());
const ground = data[id];

const emoji = {
    Aqua: '💧',
    Ignis: '🔥',
    Terra: '⛰️',
    Ventus: '🌪️',
    Lux: '☀️',
    Umbra: '🌙',
    None: '⬜',
};

if (!ground) {
    throw Astro.redirect('/404');
}
---

<Layout title={`${ground.name} | stelladb`} image={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/mapchallenge/${ground.icon}.webp`} description={`Weak: ${ground.weakTo.map((e) => e + emoji[e]).join(', ')}, Resist: ${ground.resistTo}${emoji[ground.resistTo]}, Last diff HP: ${ground.diff[ground.diff.length - 1].stat.HP.toLocaleString('en-US')}`}>
    <div class="ground-page" data-json={JSON.stringify(ground)}>
        <div class="header">
            <h1>{ground.name}</h1>

            <Tabs>
                <button data-tab="stats" class="tab active">Stats</button>
                <button data-tab="mechanic" class="tab">Mechanic</button>
            </Tabs>
        </div>

        <div class="content">
            <div class="left">
                <img src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/mapchallenge/${ground.icon}.webp`} alt={ground.name} title={ground.name} width="256" height="256" onerror="this.style.display='none'" />
                <div class="info">
                    <p class="indent">
                        {`Type: ${ground.type}`}<br />
                        {`Weak: ${ground.weakTo.map((e) => e + emoji[e]).join(', ')}`}<br />
                        {`Resist: ${ground.resistTo}${emoji[ground.resistTo]}`}<br />
                    </p>
                </div>
            </div>

            <div class="right">
                <section id="stats" class="tab-panel">
                    <div class="slider-container">
                        <div class="slider difficulty">
                            <label class="difficulty-output">Difficulty: {ground.diff.length}</label>
                            <input type="range" id="difficulty" min="0" max={ground.diff.length - 1} value={ground.diff.length - 1} />
                        </div>
                    </div>

                    <div class="stats">
                        <h2>Stats</h2>
                        <p class="indent">
                            {
                                Object.entries(ground.diff[0].stat).map(([stat, value]) => (
                                    <>
                                        {stat}: {value.toLocaleString('en-US')}
                                        {stat === 'DEF' ? ` (${Math.round(((value * 40) / (value * 32 + 24000)) * 100 * 100) / 100}%)` : ''}
                                        <br />
                                    </>
                                ))
                            }
                        </p>
                    </div>
                </section>

                <section id="mechanic" class="tab-panel" hidden>
                    {
                        ground.mechanic.map((mechanic) => (
                            <div class="mechanic">
                                <div class="mechanic-header">
                                    <img src={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/icon/monsterskill/regionaffix/${mechanic.icon}.webp`} alt={mechanic.name} title={mechanic.name} width="64" height="64" />
                                    <h3>{mechanic.name}</h3>
                                </div>
                                <p class="indent">{mechanic.desc}</p>
                            </div>
                        ))
                    }
                </section>
            </div>
        </div>
    </div>

    <script>
        // @ts-nocheck
        const ground = JSON.parse(document.querySelector('.ground-page').dataset.json);

        const difficultyInput = document.querySelector('#difficulty');
        const difficultyOutput = document.querySelector('.difficulty-output');
        const stats = document.querySelector('.stats p');

        let difficulty = 0;

        difficultyInput.addEventListener('input', onDifficultyInput);
        onDifficultyInput();

        function onDifficultyInput() {
            difficulty = +difficultyInput.value;

            difficultyOutput.innerHTML = `Difficulty: ${difficulty + 1}`;
            stats.innerHTML = `${Object.entries(ground.diff[difficulty].stat)
                .map(([stat, value]) => `${stat}: ${value.toLocaleString('en-US')}${stat === 'DEF' ? ` (${Math.round(((value * 40) / (value * 32 + 24000)) * 100 * 100) / 100}%)` : ''}<br />`)
                .join('')}`;
        }
    </script>

    <style>
        .ground-page {
            padding: 0 1rem;

            .header {
                display: flex;
                position: sticky;
                top: var(--nav-height);
                align-items: center;
                backdrop-filter: blur(5px);
                margin: 0 auto;
                background: var(--bg1a);
                padding: 0 1rem;
                max-width: 1000px;
                height: var(--nav-height);
            }

            h1 {
                margin: 0 1rem 0 0;
                font-weight: 700;
                font-size: 1.5rem;
            }

            .content {
                display: flex;
                gap: 1rem;
                padding: 1rem;

                .left {
                    width: 256px;

                    img {
                        object-fit: cover;
                        object-position: top;
                    }
                }

                .right {
                    flex: 1;
                    min-width: 0;
                }
            }

            @media (width < 800px) {
                .content {
                    flex-direction: column;
                }

                .left {
                    display: flex;
                    width: 100% !important;
                }
            }

            .slider-container {
                position: sticky;
                top: calc(var(--nav-height) * 2);
                backdrop-filter: blur(5px);
                background: var(--bg1a);
                padding: 1rem;
            }

            .slider {
                display: flex;
                align-items: center;
                gap: 0.5rem;
                width: 100%;

                label {
                    width: 16ch;
                }

                input[type='range'] {
                    flex: 1;
                    width: 100%;
                    min-width: 0;
                    accent-color: var(--accent);
                }
            }

            .mechanic-header {
                display: flex;
                align-items: center;
                gap: 1rem;
            }

            h2 {
                margin: 1rem 0;
            }

            h3 {
                margin: 0.75rem 0;
            }

            p {
                margin: 0.25rem 0;
            }
        }
    </style>
</Layout>
