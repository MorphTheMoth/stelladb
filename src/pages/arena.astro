---
// @ts-nocheck
import Card from '@/components/Card.astro';
import SearchableGrid from '@/components/SearchableGrid.astro';
import Layout from '@/layouts/Layout.astro';

const DATA_URL = 'https://raw.githubusercontent.com/AutumnVN/StellaSoraData/refs/heads/main/arena.json';

const data = await fetch(DATA_URL).then((res) => res.json());

const emoji = {
    Aqua: '💧',
    Ignis: '🔥',
    Terra: '⛰️',
    Ventus: '🌪️',
    Lux: '☀️',
    Umbra: '🌙',
    None: '⬜',
};
---

<Layout title="Arena | stelladb">
    <SearchableGrid placeholder="Search arena groups by id, name, or element..." noResultsText="No arena group found.">
        {
            Object.entries(data).map(([id, group]) => (
                <div class="card-item" data-id={id} data-name={group.name} data-weakto={group.weakTo}>
                    <Card href={`/arena/${id}`} name={group.name} desc={`Weak: ${group.weakTo}${emoji[group.weakTo]}`} desc2={group.openDayDesc} image={`https://raw.githubusercontent.com/AutumnVN/ssassets/refs/heads/main/export/assets/assetbundles/image/uibg/${group.icon}.webp`} />
                </div>
            ))
        }
    </SearchableGrid>
</Layout>
